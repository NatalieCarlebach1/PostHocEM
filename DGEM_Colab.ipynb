   "metadata": {},
   "source": [
    "## 11. Quick Smoke Test (no data needed)\n",
    "\n",
    "Generates synthetic random volumes and runs one training step to verify\n",
    "the full pipeline works before committing to a full training run."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch, torch.nn as nn, torch.nn.functional as F\n",
    "import numpy as np\n",
    "import sys\n",
    "sys.path.insert(0, '/content/PostHocEM')\n",
    "\n",
    "from networks import VNet\n",
    "from utils.losses import SupLoss, entropy_loss_masked\n",
    "from utils.ramps  import get_current_consistency_weight\n",
    "\n",
    "torch.manual_seed(42)\n",
    "PATCH = 64\n",
    "B     = 2\n",
    "\n",
    "# ── Build models ──────────────────────────────────────────────────────────\n",
    "net     = VNet(n_channels=1, n_classes=2, normalization='instancenorm',\n",
    "               has_dropout=True).cuda()\n",
    "net_ema = VNet(n_channels=1, n_classes=2, normalization='instancenorm',\n",
    "               has_dropout=True).cuda()\n",
    "net_ema.load_state_dict(net.state_dict())\n",
    "for p in net_ema.parameters(): p.detach_()\n",
    "\n",
    "optimizer   = torch.optim.Adam(net.parameters(), lr=1e-3)\n",
    "sup_loss_fn = SupLoss(n_classes=2)\n",
    "\n",
    "# ── Synthetic batch ───────────────────────────────────────────────────────\n",
    "lab_img   = torch.randn(B, 1, PATCH, PATCH, PATCH).cuda()\n",
    "lab_lbl   = torch.randint(0, 2, (B, PATCH, PATCH, PATCH)).cuda()\n",
    "unlab_img = torch.randn(B, 1, PATCH, PATCH, PATCH).cuda()\n",
    "\n",
    "# ── DGEM forward pass ────────────────────────────────────────────────────\n",
    "net.train()\n",
    "\n",
    "# Supervised\n",
    "sup_logits = net(lab_img)[0]\n",
    "sup_loss   = sup_loss_fn(sup_logits, lab_lbl)\n",
    "\n",
    "# Disagreement-guided entropy\n",
    "student_logits = net(unlab_img)[0]\n",
    "student_probs  = F.softmax(student_logits, dim=1)\n",
    "student_pred   = student_probs.argmax(dim=1)\n",
    "\n",
    "with torch.no_grad():\n",
    "    teacher_pred = F.softmax(net_ema(unlab_img)[0], dim=1).argmax(dim=1)\n",
    "\n",
    "disagree_mask = (student_pred != teacher_pred).float()\n",
    "em_loss = entropy_loss_masked(student_probs, disagree_mask)\n",
    "\n",
    "lam  = get_current_consistency_weight(epoch=1, consistency=1.0, consistency_rampup=40)\n",
    "loss = sup_loss + lam * em_loss\n",
    "\n",
    "optimizer.zero_grad()\n",
    "loss.backward()\n",
    "optimizer.step()\n",
    "\n",
    "print('=== Smoke test PASSED ===')\n",
    "print(f'  sup_loss       : {sup_loss.item():.4f}')\n",
    "print(f'  em_loss        : {em_loss.item():.4f}')\n",
    "print(f'  disagree_ratio : {disagree_mask.mean().item():.3f}')\n",
    "print(f'  lambda         : {lam:.4f}')\n",
    "print(f'  total_loss     : {loss.item():.4f}')\n",
    "print(f'  output shape   : {student_logits.shape}')"
   ]
  },
