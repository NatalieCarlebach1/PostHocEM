  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 3d. Quick sanity check: visualize one H5 case"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import h5py, numpy as np, matplotlib.pyplot as plt\n",
    "from pathlib import Path\n",
    "\n",
    "# Pick the first case\n",
    "cases = sorted(Path(DATA_ROOT).glob('*.h5'))\n",
    "assert len(cases) > 0, f'No H5 files found in {DATA_ROOT}'\n",
    "\n",
    "with h5py.File(str(cases[0]), 'r') as f:\n",
    "    image = f['image'][:]\n",
    "    label = f['label'][:]\n",
    "\n",
    "# Find slice with most pancreas\n",
    "z_idx = np.argmax(label.sum(axis=(0,1)))\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(10, 4))\n",
    "axes[0].imshow(image[:, :, z_idx], cmap='gray')\n",
    "axes[0].set_title(f'CT — axial slice {z_idx}')\n",
    "axes[0].axis('off')\n",
    "axes[1].imshow(image[:, :, z_idx], cmap='gray')\n",
    "axes[1].imshow(np.ma.masked_equal(label[:, :, z_idx], 0),\n",
    "               cmap='Reds', alpha=0.6, vmin=0.5)\n",
    "axes[1].set_title('CT + Pancreas mask')\n",
    "axes[1].axis('off')\n",
    "plt.suptitle(f'Case: {cases[0].stem} | Shape: {image.shape}', fontsize=10)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(f'Image  — shape: {image.shape}, min: {image.min():.3f}, max: {image.max():.3f}')\n",
    "print(f'Label  — unique values: {np.unique(label)}')\n",
    "print(f'Total cases in {DATA_ROOT}: {len(cases)}')"
   ]
  },
